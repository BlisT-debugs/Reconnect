generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// CORE MULTI-TENANCY SYSTEM
// ------------------------------------------------------
// ------------------------------------------------------
// CORE MULTI-TENANCY SYSTEM
// ------------------------------------------------------
model Tenant {
  id        String   @id // e.g., 'admin', 'college_a'
  name      String?
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships (A tenant has many domains, users, alumni, and academic data)
  domains      Domain[]
  users        User[]
  alumni       Alumnus[]
  batches      Batch[]
  departments  Department[]
  passingYears PassingYear[]
  jobs         Job[]
  events       Event[]
  newsCategories   NewsCategory[]
  news             News[]
  noticeCategories NoticeCategory[]
  notices          Notice[]
  campaignCategories CampaignCategory[]
  campaigns          Campaign[]
  donations          Donation[]


}

model Domain {
  id        Int      @id @default(autoincrement())
  domain    String   @unique // e.g., '127.0.0.1' or 'alumni.test'
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------
// USER AUTHENTICATION & PROFILES
// ------------------------------------------------------
model User {
  id                Int       @id @default(autoincrement())
  tenantId          String
  name              String
  email             String    @unique
  password          String
  role              String    @default("Alumni") // 'Super Admin', 'Admin', 'Alumni'
  email_verified_at DateTime?
  status            Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alumnusProfile    Alumnus?  // One-to-One relationship
  jobs         Job[]
  campaigns          Campaign[]
  donations          Donation[]
}

// ------------------------------------------------------
// ACADEMIC DATA 
// ------------------------------------------------------
model Batch {
  id        Int       @id @default(autoincrement())
  tenantId  String
  name      String
  status    Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alumni    Alumnus[]
}

model Department {
  id         Int       @id @default(autoincrement())
  tenantId   String
  name       String
  short_name String?
  status     Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alumni     Alumnus[]
}

model PassingYear {
  id        Int       @id @default(autoincrement())
  tenantId  String
  name      String
  status    Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alumni    Alumnus[]
}

// ------------------------------------------------------
// ALUMNUS PROFILE 
// ------------------------------------------------------
model Alumnus {
  id              Int       @id @default(autoincrement())
  tenantId        String
  userId          Int       @unique
  
  // Academic Foreign Keys (Mapped to tables above)
  batchId         Int?
  departmentId    Int?
  passingYearId   Int?

  // Personal Details
  first_name      String
  last_name       String
  official_email  String?   // Your custom XAMPP feature!
  nickname        String?
  phone           String?
  dob             DateTime?
  blood_group     String?
  gender          String?
  about_me        String?   @db.Text
  
  // Professional Details
  company         String?
  designation     String?
  
  // Media Files (Paths)
  profile_pic     String?
  
  // Social Links
  facebook_url    String?
  twitter_url     String?
  linkedin_url    String?
  instagram_url   String?
  github_url      String?
  
  // Location Details
  country_id      Int?      // We will map this when we build the XAMPP Country table
  state           String?
  city            String?
  zip             String?
  address         String?   @db.Text
  
  status          Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Prisma Relational Mappings
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch           Batch?       @relation(fields: [batchId], references: [id])
  department      Department?  @relation(fields: [departmentId], references: [id])
  passingYear     PassingYear? @relation(fields: [passingYearId], references: [id])
}

// ------------------------------------------------------
// JOB BOARD MODULE
// ------------------------------------------------------
model Job {
  id                  Int       @id @default(autoincrement())
  tenantId            String
  userId              Int       // The alumnus who posted the job
  
  title               String
  company             String
  location            String?
  description         String    @db.Text
  salary_range        String?
  experience_required String?
  apply_link          String?   // URL or email to apply
  deadline            DateTime?
  
  status              Int       @default(1) // 1 = Active, 0 = Closed
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Prisma Relational Mappings
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  postedBy            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// EVENTS MODULE
// ------------------------------------------------------
model Event {
  id            Int      @id @default(autoincrement())
  tenantId      String
  
  title         String
  description   String   @db.Text
  date          DateTime
  location      String
  banner_image  String?  // URL path for the uploaded poster
  
  status        Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Prisma Relational Mapping
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// NEWS & NOTICES MODULE (XAMPP Replica)
// ------------------------------------------------------

model NewsCategory {
  id        Int      @id @default(autoincrement())
  tenantId  String
  name      String
  
  news      News[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model News {
  id          Int      @id @default(autoincrement())
  tenantId    String
  categoryId  Int
  
  title       String
  image       String?  // URL path for the news thumbnail
  details     String   @db.Text
  date        DateTime @default(now())
  status      Int      @default(1) // 1 = Published, 0 = Draft
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    NewsCategory @relation(fields: [categoryId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NoticeCategory {
  id        Int      @id @default(autoincrement())
  tenantId  String
  name      String
  
  notices   Notice[]
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Notice {
  id          Int      @id @default(autoincrement())
  tenantId    String
  categoryId  Int
  
  title       String
  details     String   @db.Text
  date        DateTime @default(now())
  status      Int      @default(1)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    NoticeCategory @relation(fields: [categoryId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// FUNDRAISING & CAMPAIGNS MODULE
// ------------------------------------------------------

model CampaignCategory {
  id        Int        @id @default(autoincrement())
  tenantId  String
  name      String
  
  campaigns Campaign[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Campaign {
  id            Int      @id @default(autoincrement())
  tenantId      String
  categoryId    Int
  userId        Int      // The user/admin who organized it
  
  title         String
  description   String   @db.Text
  image         String?  // Optional banner
  target_amount Float    // How much they want to raise
  raised_amount Float    @default(0) // Automatically tracked
  deadline      DateTime
  status        Int      @default(1) 
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      CampaignCategory @relation(fields: [categoryId], references: [id])
  organizer     User             @relation(fields: [userId], references: [id])
  donations     Donation[]
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Donation {
  id          Int      @id @default(autoincrement())
  tenantId    String
  campaignId  Int
  userId      Int      // The alumnus who donated
  
  amount      Float
  status      String   @default("completed") // Will tie to payment gateways later
  
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donor       User     @relation(fields: [userId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}